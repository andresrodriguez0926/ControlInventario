rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Estas reglas solo permiten leer y escribir a usuarios que hayan iniciado sesión a través de Firebase Auth.
    // Los administradores deben crear los usuarios en la consola de Firebase con el formato usuario@control-inventario.com
    
    match /appData/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /actividad/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
